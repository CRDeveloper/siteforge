# SiteForge Environment Configuration
# Copy to .env and customize for your environment

# ============================================================================
# AWS Configuration
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# AWS credentials (or configure via aws cli: aws configure)
# Uncomment and set if not using AWS CLI credentials
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# ============================================================================
# CDK Configuration
# ============================================================================
# CDK Stack naming convention
CDK_STACK_PREFIX=SiteForge

# CDK context values (optional overrides)
# CDK_CONTEXT_ENVIRONMENT=dev

# ============================================================================
# SiteForge Configuration
# ============================================================================
# Primary demo site
PRIMARY_SITE_ID=serenity-therapy

# Python version requirement
PYTHON_VERSION=3.12

# ============================================================================
# Brevo Email Service (Optional - can be set later)
# ============================================================================
# Brevo API key for transactional email
# BREVO_API_KEY=xkeysib-your_key_here

# ============================================================================
# Local Development Configuration
# ============================================================================
FRONTEND_PORT=7000
FRONTEND_DEV_PORT=7000

# Backend/API ports (if running locally)
API_PORT=8200

# Enable local HTTPS (true/false)
ENABLE_LOCAL_HTTPS=true

# ============================================================================
# Logging & Debugging
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable verbose output in scripts
VERBOSE=false

# Log directory
LOG_DIR=./logs

# ============================================================================
# Slack Integration (Optional - for deployment notifications)
# ============================================================================
# Enable Slack notifications for deployments
SLACK_NOTIFICATIONS_ENABLED=false

# Slack webhook URL (stored in AWS Secrets Manager)
# Create in Slack: 1. Create app, 2. Enable Incoming Webhooks, 3. Add New Webhook to Workspace
# Then store in AWS Secrets Manager:
#   aws secretsmanager create-secret --name siteforge/slack-webhook-url --secret-string "https://hooks.slack.com/..."
SLACK_SECRET_NAME=siteforge/slack-webhook-url
SLACK_REGION=us-east-1

# ============================================================================
# CI/CD Configuration (Optional)
# ============================================================================
# GitHub Actions workflows (currently skipped)
# ENABLE_GITHUB_ACTIONS=false

# ============================================================================
# Notes for Setup
# ============================================================================
# 1. Before first run:
#    cp .env.example .env
#    # Edit .env with your AWS account ID and region
#
# 2. Bootstrap CDK once per AWS account/region:
#    ./scripts/setup.sh bootstrap
#
# 3. Create first site:
#    ./scripts/manage.sh create serenity-therapy \
#      --domain serenity-therapy.com \
#      --admin admin@serenity-therapy.com \
#      --name "Serenity Therapy"
#
# 4. Deploy site:
#    ./scripts/manage.sh deploy serenity-therapy
#
# 5. Local development:
#    ./scripts/manage.sh local serenity-therapy
